ENVIRONMENT=local
PROJECT_NAME=Credara Enterprise
API_HOST=0.0.0.0
API_PORT=8000
WEB_PUBLIC_API_BASE=http://localhost:8000/api/v1
# Next.js reads these (proxy keeps browser calls on /api/v1)
NEXT_PUBLIC_API_BASE=/api/v1
API_PROXY_TARGET=http://localhost:8000
# Set CREDARA_USE_SQLITE=1 or use dev-local.sh when Postgres is not running
DATABASE_URL=postgresql+psycopg://credara:credara@localhost:5432/credara
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-in-production
JWT_ISSUER=credara.local
JWT_AUDIENCE=credara.web
CORS_ORIGINS=http://localhost:3000
POLYGON_CHAIN_ID=80002
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
POLYGON_EXPLORER_BASE=https://amoy.polygonscan.com
RELAYER_PRIVATE_KEY=replace-with-dev-key-only
PROOF_REGISTRY_ADDRESS=
RECEIVABLE_REGISTRY_ADDRESS=
SMART_LC_FACTORY_ADDRESS=
CREDIT_SCORE_ATTESTATION_ADDRESS=
MOCK_USDC_ADDRESS=
OBJECT_STORAGE_BUCKET=credara-local
POLYGONSCAN_API_KEY=

# KYB provider abstraction
KYB_PROVIDER=mock
DIDIT_API_KEY=
DIDIT_WORKFLOW_ID=
DIDIT_WEBHOOK_SECRET=

# Auth0 OAuth (Regular Web App) — optional
APP_BASE_URL=http://localhost:3000
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
